# Copy this file to .env on the docker host and fill in real values.
# .env is gitignored — never commit a populated copy.

# Shared token between the dashboard container and Watchtower.
# Generate a fresh one with: openssl rand -hex 32
WATCHTOWER_HTTP_API_TOKEN=

# Optional: subject address used when signing VAPID push notifications.
# Defaults to mailto:admin@example.com if unset.
# VAPID_CONTACT=mailto:you@example.com

# Optional: override the auto-generated session secret without touching data/auth.json.
# SESSION_SECRET=
